      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.1l5fbv61928opi18jiy7l0idzn6b].[avg:graduate_rating:qk]&quot;' value='Оценка выпускника' />
          <alias key='&quot;[federated.1l5fbv61928opi18jiy7l0idzn6b].[avg:mentor_rating:qk]&quot;' value='Оценка наставника' />
