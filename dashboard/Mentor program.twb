          <alias key='&quot;[federated.1l5fbv61928opi18jiy7l0idzn6b].[usr:Calculation_2108327281139721:qk]&quot;' value='Выпускников' />
          <alias key='&quot;[federated.1l5fbv61928opi18jiy7l0idzn6b].[usr:Calculation_2108327282561034:qk]&quot;' value='Менторов' />
          <alias key='&quot;[federated.1l5fbv61928opi18jiy7l0idzn6b].[usr:Calculation_2108327282860043:qk]&quot;' value='Активных пар' />
          <alias key='&quot;[federated.1l5fbv61928opi18jiy7l0idzn6b].[usr:Calculation_2108327282982924:qk]&quot;' value='Завершенных успешно' />
          <alias key='&quot;[federated.1l5fbv61928opi18jiy7l0idzn6b].[usr:Calculation_2108327283150861:qk]&quot;' value='Встреч' />
        </aliases>
      </column>
      <column caption='Кол-во встреч' datatype='integer' name='[Calculation_2108326559199234]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([meeting_id])' />
      </column>
      <column caption='% of Total Pairs' datatype='real' name='[Calculation_2108326711943172]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([pairs_id]) / TOTAL(COUNTD([pairs_id]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Avg Combined Rating' datatype='real' name='[Calculation_2108326776225797]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG([graduate_rating]) + AVG([mentor_rating])) / 2' />
      </column>
      <column caption='СNTD Graduate' datatype='integer' name='[Calculation_2108327227621382]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([graduate_id])' />
      </column>
      <column caption='CNTD Mentors' datatype='integer' name='[Calculation_2108327227805703]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([mentor_id])' />
      </column>
      <column caption='Box' datatype='string' name='[Calculation_2108327260344328]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;&quot;' />
      </column>
      <column caption='Total Graduates' datatype='integer' name='[Calculation_2108327281139721]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([graduate_id])' />
      </column>
      <column caption='Total Mentors' datatype='integer' name='[Calculation_2108327282561034]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([mentor_id])' />
      </column>
      <column caption='Active Pairs' datatype='integer' name='[Calculation_2108327282860043]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [status] = &apos;active&apos; THEN [pairs_id] END)' />
      </column>
      <column caption='Success Rate' datatype='real' name='[Calculation_2108327282982924]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(&#13;&#10;    COUNTD(IF [status] = &apos;completed successfully&apos; THEN [pairs_id] END) / &#13;&#10;    (COUNTD(IF [status] = &apos;completed successfully&apos; THEN [pairs_id] END) + &#13;&#10;     COUNTD(IF [status] = &apos;completed early&apos; THEN [pairs_id] END)), &#13;&#10;    1&#13;&#10;)' />
      </column>
      <column caption='Total Meetings' datatype='integer' name='[Calculation_2108327283150861]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([meeting_id])' />
      </column>
      <column caption='Gap Label' datatype='real' name='[Calculation_2108327428042769]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='STR([CNTD Graduate]) + &quot; выпускников vs &quot; + STR([Calculation_2108327227805703]) + &quot; наставников&quot; + &#13;&#10;CHAR(10) + &quot;Разрыв: &quot; + STR([CNTD Graduate] - [Calculation_2108327227805703])' />
      </column>
      <column caption='Skills Gap' datatype='integer' name='[Calculation_2108327429758994]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='-COUNTD([graduate_id]) + COUNTD([mentor_id])' />
      </column>
